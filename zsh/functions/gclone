local url="$1"
# Strip protocol, trailing .git, and trailing slashes
local repo_path="${url#https://}"
repo_path="${repo_path#http://}"
repo_path="${repo_path#git@}"
repo_path="${repo_path%.git}"
repo_path="${repo_path%/}"
# Handle git@github.com:user/repo SSH format
repo_path="${repo_path/://}"

local target="$HOME/src/$repo_path"

if [[ -d "$target" ]]; then
  echo "Already exists: $target"
  return 0
fi

/bin/mkdir -p "${target%/*}"
git clone "$url" "$target"

