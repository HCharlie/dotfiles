# Brewfile.work.example — template for company/work-specific tools.
#
# Copy to `Brewfile.work` (gitignored) on a work machine and add taps
# / formulae / casks specific to your employer. Keeps work-only tools
# and private taps out of the public dotfiles repo.
#
# Apply with:        brew bundle --file=Brewfile.work
# (setup.sh applies Brewfile.work automatically if it exists.)
#
# Common categories:
#   - Cloud CLIs:   awscli, aws-vault, aws-iam-authenticator
#   - Kubernetes:   kubernetes-cli, helm, kubectx, k9s, stern, popeye
#   - Build:        bazelisk, buildifier
#   - Infra:        terraform, vault, envoy, grpc, grpcurl, protobuf
#   - Linters:      hadolint
#   - Private taps: tap "company/tools", "git@github.com:company/homebrew-tools.git"

# tap "hashicorp/tap"
# brew "hashicorp/tap/terraform"
# brew "awscli"
# brew "kubernetes-cli"
